{
  "version": 2,
  "builds": [
    {
      "src": "web/build/**",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["api/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/web/build/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/sentinel/process-queue",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/daily-refresh?secret=Overkill123*",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/send-scheduled-reports",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/sync-rockenue-assets",
      "schedule": "0 6 * * *"
    }
  ]
}
